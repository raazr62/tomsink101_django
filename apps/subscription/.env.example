# Subscription Payment Configuration
# Copy this to your .env file and fill in your credentials

# ======================
# STRIPE CONFIGURATION
# ======================
# Get these from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_51xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_KEY=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Note: Success/Cancel URLs are hardcoded in settings.py
# Change them in project/settings.py if needed

# ======================
# PAYPAL CONFIGURATION
# ======================
# Get these from: https://developer.paypal.com/dashboard/applications/sandbox

# Sandbox Credentials (for testing)
PAYPAL_CLIENT_ID=AxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxZg
PAYPAL_CLIENT_SECRET=ExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxUg
PAYPAL_MODE=sandbox

# Production Credentials (uncomment for live payments)
# PAYPAL_CLIENT_ID=your_live_client_id
# PAYPAL_CLIENT_SECRET=your_live_client_secret
# PAYPAL_MODE=live

# ======================
# NOTES
# ======================
# 1. Never commit .env file to git
# 2. Keep your secret keys secure
# 3. Use sandbox mode for testing
# 4. Switch to live mode only in production
# 5. Update webhook URLs in respective dashboards

# ======================
# WEBHOOK URLS
# ======================
# Stripe Webhook: https://yourdomain.com/api/subscription/webhook/
# PayPal Webhook: https://yourdomain.com/api/subscription/paypal-webhook/

# For local testing with ngrok:
# 1. Run: ngrok http 8000
# 2. Use the ngrok URL for webhooks
# Example: https://abc123.ngrok.io/api/subscription/webhook/
